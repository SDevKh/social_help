# Copy values into Azure App Settings

SECRET_KEY="replace-me"
DEBUG="false"

# If you want Azure PostgreSQL, set this.
# Example (adjust for your DB):
# DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/DBNAME"
DATABASE_URL=""

ALLOWED_HOSTS="<your-webapp-name>.azurewebsites.net"

# Instagram
INSTAGRAM_APP_ID=""
INSTAGRAM_APP_SECRET=""
INSTAGRAM_PAGE_ID=""
INSTAGRAM_BUSINESS_ACCOUNT_ID=""
INSTAGRAM_ACCESS_TOKEN=""
INSTAGRAM_PAGE_ACCESS_TOKEN=""
INSTAGRAM_REDIRECT_URI="https://<your-webapp-name>.azurewebsites.net/instagram/callback/"

# Facebook OAuth
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
FACEBOOK_OAUTH_REDIRECT_URI="https://<your-webapp-name>.azurewebsites.net/instagram/callback/"

# Stripe
STRIPE_PUBLIC_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Polar
POLAR_ACCESS_TOKEN=""
POLAR_ORGANIZATION_ID=""
POLAR_WEBHOOK_SECRET=""
POLAR_API_BASE_URL="https://api.polar.sh/v1"

# PayPal
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_MODE="sandbox"
PAYPAL_CLIENT_WEBHOOK_ID=""

# Domain
DOMAIN_URL="https://<your-webapp-name>.azurewebsites.net"

# CSRF trusted origins (optional)
CSRF_TRUSTED_ORIGINS="https://<your-webapp-name>.azurewebsites.net"

# AI Moderation Keys (Hugging Face & Groq)
HUGGINGFACE_API_KEY=""
GROQ_API_KEY=""

