{
  "builds": [
    {
      "src": "social_help/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.11"
      }
    },
    {
      "src": "build_files.sh",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "staticfiles"
      }
    }
  ],
  "routes": [
    {
      "src": "/google1e281c209d0ab913.html",
      "dest": "/staticfiles/google1e281c209d0ab913.html"
    },
    {
      "src": "/BingSiteAuth.xml",
      "dest": "/staticfiles/BingSiteAuth.xml"
    },
    {
      "src": "/static/(.*)",
      "dest": "/staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "social_help/wsgi.py"
    }
  ]
}
